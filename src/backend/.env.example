ENV=development
API_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000

# Firebase Admin — 둘 중 하나만 채우면 됨
# 방법 A (권장): service account JSON file 경로
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=

# 방법 B: 개별 env (Vercel/Heroku 등 file system 제한 환경)
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# AI Providers
CLAUDE_API_KEY=
OPENAI_API_KEY=
LYRIA_API_KEY=
VEO_API_KEY=
WHISPER_API_KEY=

# Misc
JWT_SECRET=change_me
TEMP_DIR=./temp
OUTPUT_DIR=./output

# Provider switches: live | mock
LYRICS_PROVIDER=mock
MUSIC_PROVIDER=mock
IMAGE_PROVIDER=mock
VIDEO_PROVIDER=mock
SUBTITLE_PROVIDER=mock
