rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthed() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuthed() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read, write: if isOwner(uid);
    }

    match /projects/{projectId} {
      allow read: if isOwner(resource.data.uid);
      allow create: if isAuthed() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isOwner(resource.data.uid);
    }

    match /renders/{renderId} {
      allow read: if isOwner(resource.data.uid);
      allow write: if false; // backend only
    }

    match /assets/{assetId} {
      allow read: if isOwner(resource.data.uid);
      allow write: if false; // backend only
    }
  }
}
